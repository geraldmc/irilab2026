    "    print(\"DEV_MODE is OFF — full production run.\")\n",
    "    print(f\"    PD variant: {PD_VARIANT}\")\n",
    "    print(f\"    PV subsample: full test split\")\n",
    "    print(f\"    Bootstrap cap: honor precommit n_bootstrap\")"

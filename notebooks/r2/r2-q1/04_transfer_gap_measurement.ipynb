    "    print(\"⚠️  DEV_MODE is ON — numbers produced are NOT paper-ready.\")\n",
    "    print(f\"    PD variant: {PD_VARIANT}\")\n",
    "    print(f\"    PV subsample: {PV_SUBSAMPLE_N:,} images\")\n",
    "    print(f\"    Bootstrap cap: {BOOTSTRAP_CAP} iterations\")\n",
    "else:\n",
